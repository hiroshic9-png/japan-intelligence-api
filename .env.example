# Japan Intelligence API — Environment Variables
# Copy this file to .env and fill in your API keys

# EDINET API (https://disclosure2dl.edinet-fsa.go.jp/)
EDINET_API_KEY=

# Google Gemini API (https://ai.google.dev/)
GEMINI_API_KEY=

# gBizINFO API (https://info.gbiz.go.jp/api/index.html)
GBIZ_API_TOKEN=

# e-Stat API (https://www.e-stat.go.jp/api/)
ESTAT_APP_ID=

# J-Quants API v2 (https://jpx-jquants.com/)
JQUANTS_API_KEY=

# FRED API (https://fred.stlouisfed.org/docs/api/)
FRED_API_KEY=

# API Authentication (optional — enables auth when set)
JI_API_KEY=

# Rate limit per hour (optional, default: 100)
# RATE_LIMIT_PER_HOUR=100
